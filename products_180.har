            "text": "{\"jsonrpc\": \"2.0\", \"id\": 8, \"result\": {\"id\": 529, \"name\": \"Requests for Quotation\", \"type\": \"ir.actions.act_window\", \"xml_id\": \"purchase.purchase_rfq\", \"help\": \"<p class=\\\"o_view_nocontent_smiling_face\\\">\\n                No request for quotation found. Let's create one!\\n              </p><p>\\n                Requests for quotation are documents that will be sent to your suppliers to request prices for different products you consider buying.\\n                Once an agreement has been found with the supplier, they will be confirmed and turned into purchase orders.\\n              </p>\\n            \", \"binding_model_id\": false, \"binding_type\": \"action\", \"binding_view_types\": \"list,form\", \"display_name\": \"Requests for Quotation\", \"view_id\": [1498, \"purchase.order.inherit.purchase.order.tree\"], \"domain\": \"[]\", \"context\": \"{'quotation_only': True}\", \"res_id\": 0, \"res_model\": \"purchase.order\", \"target\": \"current\", \"view_mode\": \"list,kanban,form,pivot,graph,calendar,activity\", \"mobile_view_mode\": \"kanban\", \"views\": [[1498, \"list\"], [false, \"kanban\"], [false, \"form\"], [false, \"pivot\"], [false, \"graph\"], [false, \"calendar\"], [false, \"activity\"]], \"limit\": 80, \"groups_id\": [], \"search_view_id\": [1494, \"request.quotation.select\"], \"filter\": false}}"
