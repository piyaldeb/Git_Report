            "mimeType": "image/svg+xml",
            "text": "<svg xmlns=\"http://www.w3.org/2000/svg\" class=\"o_spinner\" viewBox=\"0 0 50 50\" width=\"50\" height=\"50\">\n    <style>\n        @keyframes dash {\n            0% {\n                stroke-dashoffset: 120;\n                stroke-width: 2px;\n            }\n            35%, 50% {\n                stroke-dashoffset: 0;\n                stroke-width: 8px;\n            }\n            85%, 100% {\n                stroke-dashoffset: -120;\n                stroke-width: 2px;   \n            }\n        }\n        @keyframes rotate {\n            0% {\n                transform: rotate(0deg);\n            }\n            100% {\n                transform: rotate(360deg);\n            }\n        }\n        svg {\n            animation: rotate 1s linear infinite;\n        }\n        circle {\n            stroke-dasharray: 120, 120;\n            animation: dash 2.5s ease infinite;\n        }\n    </style>\n    <circle cy=\"25\" cx=\"25\" r=\"19\" stroke=\"#fff\" stroke-width=\"2\" fill=\"none\" stroke-linecap=\"round\"/>\n</svg>\n"
