any2one\"}, \"message_is_follower\": {\"change_default\": false, \"name\": \"message_is_follower\", \"readonly\": true, \"required\": false, \"searchable\": true, \"sortable\": false, \"store\": false, \"string\": \"Is Follower\", \"type\": \"boolean\"}, \"message_follower_ids\": {\"change_default\": false, \"context\": {}, \"domain\": [], \"groups\": \"base.group_user\", \"name\": \"message_follower_ids\", \"readonly\": false, \"relation\": \"mail.followers\", \"relation_field\": \"res_id\", \"required\": false, \"searchable\": true, \"sortable\": false, \"store\": true, \"string\": \"Followers\", \"type\": \"one2many\"}, \"message_partner_ids\": {\"change_default\": false, \"context\": {}, \"domain\": [], \"groups\": \"base.group_user\", \"name\": \"message_partner_ids\", \"readonly\": false, \"relation\": \"res.partner\", \"required\": false, \"searchable\": true, \"sortable\": false, \"store\": false, \"string\": \"Followers (Partners)\", \"type\": \"many2many\"}, \"message_ids\": {\"change_default\": false, \"context\": {}, \"domain\": [[\"message_type\", \"!=\", \"user_notification\"]], \"name\": \"message_ids\", \"readonly\": false, \"relation\": \"mail.message\", \"relation_field\": \"res_id\", \"required\": false, \"searchable\": true, \"sortable\": false, \"store\": true, \"string\": \"Messages\", \"type\": \"one2many\"}, \"has_message\": {\"change_default\": false, \"name\": \"has_message\", \"readonly\": true, \"required\": false, \"searchable\": true, \"sortable\": false, \"store\": false, \"string\": \"Has Message\", \"type\": \"boolean\"}, \"message_needaction\": {\"change_default\": false, \"help\": \"If checked, new messages require your attention.\", \"name\": \"message_needaction\", \"readonly\": true, \"required\": false, \"searchable\": true, \"sortable\": false, \"store\": false, \"string\": \"Action Needed\", \"type\": \"boolean\"}, \"message_needaction_counter\": {\"change_default\": false, \"group_operator\": \"sum\", \"help\": \"Number of messages requiring action\", \"name\": \"message_needaction_counter\", \"readonly\": true, \"required\": false, \"searchable\": false, \"sortable\": false, \"store\": false, \"string\": \"Number of Actions\", \"type\": \"integer\"}, \"message_has_error\": {\"change_default\": false, \"help\": \"If checked, some messages have a delivery error.\", \"name\": \"message_has_error\", \"readonly\": true, \"required\": false, \"searchable\": true, \"sortable\": false, \"store\": false, \"string\": \"Message Delivery error\", \"type\": \"boolean\"}, \"message_has_error_counter\": {\"change_default\": false, \"group_operator\": \"sum\", \"help\": \"Number of messages with delivery error\", \"name\": \"message_has_error_counter\", \"readonly\": true, \"required\": false, \"searchable\": false, \"sortable\": false, \"store\": false, \"string\": \"Number of errors\", \"type\": \"integer\"}, \"message_attachment_count\": {\"change_default\": false, \"group_operator\": \"sum\", \"groups\": \"base.group_user\", \"name\": \"message_attachment_count\", \"readonly\": true, \"required\": false, \"searchable\": false, \"sortable\": false, \"store\": false, \"string\": \"Attachment Count\", \"type\": \"integer\"}, \"rating_ids\": {\"change_default\": false, \"context\": {}, \"domain\": [[\"res_model\", \"=\", \"purchase.order\"]], \"groups\": \"base.group_user\", \"name\": \"rating_ids\", \"readonly\": false, \"relation\": \"rating.rating\", \"relation_field\": \"res_id\", \"required\": false, \"searchable\": true, \"sortable\": false, \"store\": true, \"string\": \"Ratings\", \"type\": \"one2many\"}, \"website_message_ids\": {\"change_default\": false, \"context\": {}, \"domain\": [[\"model\", \"=\", \"purchase.order\"], [\"message_type\", \"in\", [\"comment\", \"email\", \"email_outgoing\", \"auto_comment\"]]], \"help\": \"Website communication history\", \"name\": \"website_message_ids\", \"readonly\": false, \"relation\": \"mail.message\", \"relation_field\": \"res_id\", \"required\": false, \"searchable\": true, \"sortable\": false, \"store\": true, \"string\": \"Website Messages\", \"type\": \"one2many\"}, \"message_has_sms_error\": {\"change_default\": false, \"help\": \"If checked, some messages have a delivery error.\", \"name\": \"message_has_sms_error\", \"readonly\": true, \"required\": false, \"searchable\": true, \"sortable\": false, \"store\": false, \"string\": \"SMS Delivery error\", \"type\": \"boolean\"}, \"access_url\": {\"change_default\": false, \"help\": \"Customer Portal URL\", \"name\": \"access_url\", \"readonly\": true, \"required\": false, \"searchable\": false, \"sortable\": false, \"store\": false, \"string\": \"Portal Access URL\", \"translate\": false, \"trim\": true, \"type\": \"char\"}, \"access_token\": {\"change_default\": false, \"name\": \"access_token\", \"readonly\": false, \"required\": false, \"searchable\": true, \"sortable\": true, \"store\": true, \"string\": \"Security Token\", \"translate\": false, \"trim\": true, \"type\": \"char\"}, \"access_warning\": {\"change_default\": false, \"name\": \"access_warning\", \"readonly\": true, \"required\": false, \"searchable\": false, \"sortable\": false, \"store\": false, \"string\": \"Access warning\", \"translate\": false, \"type\": \"text\"}, \"name\": {\"change_default\": false, \"name\": \"name\", \"readonly\": false, \"required\": true, \"searchable\": true, \"sortable\": true, \"store\": true, \"string\": \"Order Reference\", \"translate\": false, \"trim\": true, \"type\": \"char\"}, \"priority\": {\"change_default\": false, \"name\": \"priority\", \"readonly\": false, \"required\": false, \"searchable\": true, \"selection\": [[\"0\", \"Normal\"], [\"1\", \"Urgent\"]], \"sortable\": true, \"store\": true, \"string\": \"Priority\", \"type\": \"selection\"}, \"origin\": {\"change_default\": false, \"help\": \"Reference of the document that generated this purchase order request (e.g. a sales order)\", \"name\": \"origin\", \"readonly\": false, \"required\": false, \"searchable\": true, \"sortable\": true, \"store\": true, \"string\": \"Source Document\", \"translate\": false, \"trim\": true, \"type\": \"char\"}, \"partner_ref\": {\"change_default\": false, \"help\": \"Reference of the sales order or bid sent by the vendor. It's used to do the matching when you receive the products as this reference is usually written on the delivery order sent by your vendor.\", \"name\": \"partner_ref\", \"readonly\": false, \"required\": false, \"searchable\": true, \"sortable\": true, \"store\": true, \"string\": \"Vendor Reference\", \"translate\": false, \"trim\": true, \"type\": \"char\"}, \"date_order\": {\"change_default\": false, \"help\": \"Depicts the date within which the Quotation should be confirmed and converted into a purchase order.\", \"name\": \"date_order\", \"readonly\": false, \"required\": true, \"searchable\": true, \"sortable\": true, \"store\": true, \"string\": \"Order Deadline\", \"type\": \"datetime\"}, \"date_approve\": {\"change_default\": false, \"name\": \"date_approve\", \"readonly\": true, \"required\": false, \"searchable\": true, \"sortable\": true, \"store\": true, \"string\": \"Confirmation Date\", \"type\": \"datetime\"}, \"partner_id\": {\"change_default\": true, \"context\": {}, \"domain\": \"(company_id and ['|', ('company_id', '=', False), ('company_id', 'parent_of', [company_id])] or ['|', ('company_id', '=', False), ('company_id', 'parent_of', [''])]) + ([])\", \"help\": \"You can find a vendor by its Name, TIN, Email or Internal Reference.\", \"name\": \"partner_id\", \"readonly\": false, \"relation\": \"res.partner\", \"required\": true, \"searchable\": true, \"sortable\": true, \"store\": true, \"string\": \"Vendor\", \"type\": \"many2one\"}, \"dest_address_id\": {\"change_default\": false, \"context\": {}, \"domain\": \"(company_id and ['|', ('company_id', '=', False), ('company_id', 'parent_of', [company_id])] or ['|', ('company_id', '=', False), ('company_id', 'parent_of', [''])]) + ([