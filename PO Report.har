            "mimeType": "application/json",
            "text": "{\"jsonrpc\": \"2.0\", \"id\": 5, \"result\": {\"views\": {\"list\": {\"arch\": \"<tree string=\\\"Purchase Order\\\" decoration-info=\\\"state in ['draft', 'sent']\\\" decoration-muted=\\\"state == 'cancel'\\\" class=\\\"o_purchase_order\\\" js_class=\\\"purchase_dashboard_list_custom\\\" sample=\\\"1\\\">\\n                    <header>\\n                        <button name=\\\"action_create_invoice\\\" type=\\\"object\\\" string=\\\"Create Bills\\\"/>\\n                   \\n                    \\n                   \\n                    <!-- <button name=\\\"button_approveship\\\" type=\\\"object\\\"  string=\\\"Approve\\\"\\n                        class=\\\"oe_stat_button\\\" \\n                        icon=\\\"fa-check-square-o\\\"/>\\n                    <button name=\\\"button_rejectship\\\" type=\\\"object\\\"  string=\\\"Reject\\\"\\n                        class=\\\"oe_stat_button\\\" \\n                        icon=\\\"fa-check-square-o\\\"/> -->\\n                    </header>\\n                    <field name=\\\"priority\\\" optional=\\\"show\\\" widget=\\\"priority\\\" nolabel=\\\"1\\\"/>\\n                    <field name=\\\"partner_ref\\\" optional=\\\"hide\\\"/>\\n                <field name=\\\"has_alternatives\\\" column_invisible=\\\"True\\\"/>\\n                <button class=\\\"fa fa-copy\\\" title=\\\"Has Alternatives\\\" disabled=\\\"1\\\" invisible=\\\"not has_alternatives\\\"/>\\n                    <field name=\\\"name\\\" string=\\\"Reference\\\" readonly=\\\"1\\\" decoration-bf=\\\"1\\\"/>\\n                    \\n                    <field name=\\\"partner_id\\\" readonly=\\\"1\\\" on_change=\\\"1\\\"/>\\n    <field name=\\\"x_studio_pi_no\\\"/>\\n    <field name=\\\"create_date\\\"/>\\n    <field name=\\\"x_studio_order_status\\\" optional=\\\"hidden\\\"/>\\n                    <field name=\\\"company_id\\\" readonly=\\\"1\\\" options=\\\"{'no_create': True}\\\" optional=\\\"show\\\" on_change=\\\"1\\\"/>\\n                    \\n                    <field name=\\\"date_planned\\\" column_invisible=\\\"context.get('quotation_only', False)\\\" optional=\\\"show\\\" on_change=\\\"1\\\"/>\\n                    <field name=\\\"user_id\\\" optional=\\\"show\\\" widget=\\\"many2one_avatar_user\\\" column_invisible=\\\"1\\\"/>\\n    <field name=\\\"create_uid\\\"/>\\n                   <field name=\\\"last_approver\\\"/>\\n                   <field name=\\\"next_approver\\\" force_save=\\\"1\\\"/>\\n                    <field name=\\\"date_approve\\\" column_invisible=\\\"context.get('quotation_only', False)\\\"/><field name=\\\"activity_ids\\\" widget=\\\"list_activity\\\" optional=\\\"show\\\" column_invisible=\\\"1\\\"/>\\n                    <field name=\\\"origin\\\" optional=\\\"hidden\\\"/>\\n                    <field name=\\\"amount_untaxed\\\" sum=\\\"Total Untaxed amount\\\" string=\\\"Untaxed\\\" widget=\\\"monetary\\\" optional=\\\"hide\\\"/>\\n                    <field name=\\\"amount_total\\\" widget=\\\"monetary\\\" optional=\\\"show\\\" decoration-bf=\\\"1\\\" sum=\\\"Sum of Total\\\"/>\\n    <field name=\\\"x_studio_currency\\\" string=\\\"Currency\\\"/>\\n    <field name=\\\"x_studio_gate_entry\\\" optional=\\\"hidden\\\"/>\\n               <field name=\\\"currency_id\\\" column_invisible=\\\"True\\\" readonly=\\\"state in ['cancel', 'done', 'purchase']\\\" on_change=\\\"1\\\"/>\\n                    <field name=\\\"state\\\" optional=\\\"show\\\" widget=\\\"badge\\\" decoration-success=\\\"state == 'purchase' or state == 'done'\\\" decoration-warning=\\\"state == 'to approve'\\\" decoration-info=\\\"state == 'draft' or state == 'sent'\\\" on_change=\\\"1\\\"/>\\n                    <field name=\\\"invoice_status\\\" optional=\\\"hide\\\"/>\\n                </tree>\", \"id\": 1498, \"model\": \"purchase.order\", \"toolbar\": {\"print\": [{\"id\": 2348, \"name\": \"PURCHASE ACCOUNT REPORT\", \"binding_view_types\": \"list,form\"}, {\"id\": 2349, \"name\": \"PURCHASE VENDOR REPORT\", \"binding_view_types\": \"list,form\"}, {\"id\": 2350, \"name\": \"PURCHASE QOUTATION REPORT\", \"binding_view_types\": \"list,form\"}], \"action\": [{\"id\": 1643, \"name\": \"Accrued Expense Entry\", \"binding_view_types\": \"list,form\"}, {\"id\": 531, \"name\": \"Create Vendor Bills\", \"binding_view_types\": \"list,form\", \"sequence\": 5}, {\"id\": 2375, \"name\": \"Download ZIP Purchase\", \"binding_view_types\": \"list,form\", \"sequence\": 5}]}}, \"kanban\": {\"arch\": \"<kanban class=\\\"o_kanban_mobile\\\" js_class=\\\"purchase_dashboard_kanban_custom\\\" sample=\\\"1\\\" quick_create=\\\"false\\\">\\n                    <field name=\\\"name\\\"/>\\n                    <field name=\\\"partner_id\\\" readonly=\\\"1\\\" on_change=\\\"1\\\"/>\\n                    <field name=\\\"amount_total\\\"/>\\n                    <field name=\\\"state\\\"/>\\n                    <field name=\\\"date_order\\\"/>\\n                    <field name=\\\"currency_id\\\" readonly=\\\"1\\\"/>\\n                    <field name=\\\"activity_state\\\"/>\\n                    <progressbar field=\\\"activity_state\\\" colors=\\\"{&quot;planned&quot;: &quot;success&quot;, &quot;today&quot;: &quot;warning&quot;, &quot;overdue&quot;: &quot;danger&quot;}\\\"/>\\n                    <templates>\\n                        <t t-name=\\\"kanban-box\\\">\\n                            <div t-attf-class=\\\"oe_kanban_card oe_kanban_global_click\\\">\\n                                <div class=\\\"o_kanban_record_top mb16\\\">\\n                                    <field name=\\\"priority\\\" widget=\\\"priority\\\"/>\\n                                    <div class=\\\"o_kanban_record_headings ms-1\\\">\\n                                        <strong class=\\\"o_kanban_record_title\\\"><span><t t-esc=\\\"record.partner_id.value\\\"/></span></strong>\\n                                    </div>\\n                                    <strong><field name=\\\"amount_total\\\" widget=\\\"monetary\\\"/></strong>\\n                                </div>\\n                                <div class=\\\"o_kanban_record_bottom\\\">\\n                                    <div class=\\\"oe_kanban_bottom_left\\\">\\n                                        <span><t t-esc=\\\"record.name.value\\\"/> <t t-esc=\\\"record.date_order.value and record.date_order.value.split(' ')[0] or False\\\"/></span>\\n                                        <field name=\\\"activity_ids\\\" widget=\\\"kanban_activity\\\" on_change=\\\"1\\\"/>\\n                                    </div>\\n                                    <div class=\\\"oe_kanban_bottom_right\\\">\\n                                        <field name=\\\"state\\\" widget=\\\"label_selection\\\" options=\\\"{'classes': {'draft': 'default', 'cancel': 'default', 'done': 'success', 'approved': 'warning'}}\\\"/>\\n                                    </div>\\n                                </div>\\n                            </div>\\n                        </t>\\n                    </templates>\\n                </kanban>\", \"id\": 1496, \"model\": \"purchase.order\", \"toolbar\": {}}, \"form\": {\"arch\": \"<form string=\\\"Purchase Order\\\" class=\\\"o_purchase_order\\\">\\n                <header>\\n                    <button name=\\\"action_rfq_send\\\" invisible=\\\"state != 'draft'\\\" string=\\\"Send by Email\\\" type=\\\"object\\\" context=\\\"{'send_rfq':True}\\\" class=\\\"oe_highlight\\\" data-hotkey=\\\"g\\\"/>\\n                <button name=\\\"action_view_picking\\\" string=\\\"Receive Products\\\" class=\\\"oe_highlight\\\" type=\\\"object\\\" invisible=\\\"is_shipped or state not in ('purchase', 'done') or incoming_picking_count == 0\\\" data-hotkey=\\\"y\\\"/>\\n                    <button name=\\\"print_quotation\\\" string=\\\"Print RFQ\\\" type=\\\"object\\\" invisible=\\\"state != 'draft'\\\" class=\\\"oe_highlight\\\" data-hotkey=\\\"k\\\"/>\\n                    <button name=\\\"button_confirm\\\" type=\\\"object\\\" invisible=\\\"state != &quot;sent&quot; or ( next_approver != uid )\\\" string=\\\"Confirm Order\\\" context=\\\"{'validate_analytic': True}\\\" class=\\\"oe_highlight\\\" id=\\\"bid_confirm\\\" data-hotkey=\\\"q\\\" effect=\\\"{&quot;message&quot;:&quot;Well Done!&quot;,&quot;fadeout&quot;:&quot;fast&quot;}\\\" studio_approval=\\\"True\\\"/>\\n                    <!-- <button name=\\\"download_excel\\\" type=\\\"object\\\" string=\\\"Download Excel\\\"/> -->\\n                    <button name=\\\"submit_for_approval\\\" type=\\\"object\\\" class=\\\"btn-primary\\\" string=\\\"Submit\\\" invisible=\\\"submit_status\\\"/>\\n                    <!-- <button name=\\\"approve_ord\\\" type=\\\"object\\\" string=\\\"Approve\\\"/> -->\\n                    \\n                    \\n                    <button name=\\\"action_open_wizard\\\" type=\\\"object\\\" string=\\\"Change Shipment\\\" invisible=\\\"1\\\"/>\\n                    <!-- <button name=\\\"approve_shipmentmode\\\" type=\\\"object\\\" string=\\\"Conf Shipment\\\" invisible=\\\"not cshipment or shipment_mode == cshipment\\\"/> -->\\n                    \\n                    <field name=\\\"cshipment\\\" invisible=\\\"1\\\" can_create=\\\"True\\\" can_write=\\\"True\\\"/>\\n                    <field name=\\\"submit_status\\\" invisible=\\\"1\\\"/>\\n                    <field name=\\\"next_approver\\\" invisible=\\\"1\\\" can_create=\\\"True\\\" can_write=\\\"True\\\"/>\\n                    <field name=\\\"shipment_mode\\\" invisible=\\\"1\\\" can_create=\\\"True\\\" can_write=\\\"True\\\"/>\\n                    \\n                    \\n                    <button name=\\\"action_create_invoice\\\" string=\\\"Create Bill\\\" type=\\\"object\\\" class=\\\"oe_highlight\\\" context=\\\"{'create_bill':True}\\\" invisible=\\\"state not in ('purchase', 'done') or invoice_status in ('no', 'invoiced')\\\" data-hotkey=\\\"w\\\"/>\\n                    <button name=\\\"action_rfq_send\\\" invisible=\\\"state != 'sent'\\\" string=\\\"Re-Send by Email\\\" type=\\\"object\\\" context=\\\"{'send_rfq':True}\\\" data-hotkey=\\\"g\\\"/>\\n                    <button name=\\\"print_quotation\\\" string=\\\"Print RFQ\\\" type=\\\"object\\\" invisible=\\\"state != 'sent'\\\" data-hotkey=\\\"k\\\"/>\\n                    <button name=\\\"button_confirm\\\" type=\\\"object\\\" invisible=\\\"state != &quot;draft&quot; or ( next_approver != uid )\\\" context=\\\"{'validate_analytic': True}\\\" string=\\\"Confirm Order\\\" id=\\\"draft_confirm\\\" data-hotkey=\\\"q\\\" effect=\\\"{&quot;message&quot;:&quot;Well Done!&quot;,&quot;fadeout&quot;:&quot;fast&quot;}\\\" studio_approval=\\\"True\\\"/>\\n                    <button name=\\\"action_rfq_send\\\" invisible=\\\"state != 'purchase'\\\" string=\\\"Send PO by Email\\\" type=\\\"object\\\" context=\\\"{'send_rfq':False}\\\" data-hotkey=\\\"g\\\"/>\\n                    <button name=\\\"confirm_reminder_mail\\\" string=\\\"Confirm Receipt Date\\\" type=\\\"object\\\" invisible=\\\"state not in ('purchase', 'done') or mail_reminder_confirmed or not date_planned or effective_date\\\" data-hotkey=\\\"o\\\"/>\\n                    <button name=\\\"action_create_invoice\\\" string=\\\"Create Bill\\\" type=\\\"object\\\" context=\\\"{'create_bill':True}\\\" invisible=\\\"state not in ('purchase', 'done') or invoice_status not in ('no', 'invoiced') or not order_line\\\" data-hotkey=\\\"w\\\"/>\\n                    <button name=\\\"button_draft\\\" invisible=\\\"state != 'cancel'\\\" string=\\\"Set to Draft\\\" type=\\\"object\\\" data-hotkey=\\\"o\\\"/>\\n                    <button name=\\\"button_cancel\\\" invisible=\\\"state not in ('draft', 'to approve', 'sent', 'purchase')\\\" string=\\\"Cancel\\\" type=\\\"object\\\" data-hotkey=\\\"x\\\"/>\\n                    <button name=\\\"button_done\\\" type=\\\"object\\\" string=\\\"Lock\\\" invisible=\\\"state != 'purchase'\\\" data-hotkey=\\\"l\\\"/>\\n                    \\n                    <field name=\\\"state\\\" widget=\\\"statusbar\\\" statusbar_visible=\\\"draft,sent,purchase\\\" readonly=\\\"1\\\" on_change=\\\"1\\\"/>\\n                </header>\\n                <sheet>\\n                    <div class=\\\"oe_button_box\\\" name=\\\"button_box\\\">\\n                        <button type=\\\"object\\\" name=\\\"action_view_invoice\\\" class=\\\"oe_stat_button\\\" icon=\\\"fa-pencil-square-o\\\" invisible=\\\"invoice_count == 0 or state in ('draft', 'sent', 'to approve')\\\">\\n                            <field name=\\\"invoice_count\\\" widget=\\\"statinfo\\\" string=\\\"Vendor Bills\\\"/>\\n                            <field name=\\\"invoice_ids\\\" invisible=\\\"1\\\"/>\\n                        </button>\\n                <button type=\\\"object\\\" name=\\\"action_view_picking\\\" class=\\\"oe_stat_button\\\" icon=\\\"fa-truck\\\" invisible=\\\"incoming_picking_count == 0\\\">\\n                    <field name=\\\"incoming_picking_count\\\" widget=\\\"statinfo\\\" string=\\\"Receipt\\\" help=\\\"Incoming Shipments\\\"/>\\n                </button>\\n                <button class=\\\"oe_stat_button\\\" name=\\\"action_view_mrp_productions\\\" type=\\\"object\\\" icon=\\\"fa-wrench\\\" invisible=\\\"mrp_production_count == 0\\\">\\n                    <div class=\\\"o_field_widget o_stat_info\\\">\\n                        <span class=\\\"o_stat_value\\\"><field name=\\\"mrp_production_count\\\"/></span>\\n                        <span class=\\\"o_stat_text\\\">Manufacturing</span>\\n                    </div>\\n                </button>\\n                <button class=\\\"oe_stat_button\\\" name=\\\"action_view_sale_orders\\\" type=\\\"object\\\" icon=\\\"fa-dollar\\\" invisible=\\\"sale_order_count == 0\\\">\\n                    <div class=\\\"o_field_widget o_stat_info\\\">\\n                        <span class=\\\"o_stat_value\\\"><field name=\\\"sale_order_count\\\"/></span>\\n                        <span class=\\\"o_stat_text\\\">Sale</span>\\n                    </div>\\n                </button>\\n                    </div>\\n                    <div class=\\\"oe_title\\\">\\n                        <span class=\\\"o_form_label\\\" invisible=\\\"state not in ('draft', 'sent')\\\">Request for Quotation </span>\\n                        <span class=\\\"o_form_label\\\" invisible=\\\"state in ('draft', 'sent')\\\">Purchase Order </span>\\n                        <h1 class=\\\"d-flex\\\">\\n                            <field name=\\\"priority\\\" widget=\\\"priority\\\" class=\\\"me-3\\\"/>\\n                            <field name=\\\"name\\\" readonly=\\\"1\\\"/>\\n                        </h1>\\n                    </div>\\n                    <group>\\n                        <group>\\n                            <field name=\\\"is_quantity_copy\\\" invisible=\\\"1\\\"/>\\n    <field name=\\\"revision_number\\\" force_save=\\\"1\\\" readonly=\\\"True\\\"/>\\n                <field name=\\\"partner_id\\\" widget=\\\"res_partner_many2one\\\" context=\\\"{'res_partner_search_mode': 'supplier', 'show_vat': True}\\\" readonly=\\\"(state == 'purchase') or (state == 'to approve')\\\" placeholder=\\\"Name, TIN, Email, or Reference\\\" force_save=\\\"1\\\" options=\\\"{'no_create': True, 'no_quick_create': True, 'no_create_edit':True, 'no_open': True}\\\" on_change=\\\"1\\\" can_create=\\\"True\\\" can_write=\\\"True\\\"/>\\n            <field name=\\\"partner_ref\\\"/>\\n                <field name=\\\"x_studio_pi_no\\\" string=\\\"PI No.\\\"/>\\n    <field name=\\\"x_studio_gate_entry\\\" string=\\\"Gate Entry\\\"/>\\n    <field name=\\\"x_studio_gate_entry_no\\\" string=\\\"Gate Entry No.\\\"/>\\n    <field name=\\\"x_studio_gate_entry_date\\\" string=\\\"Gate Entry Date\\\"/>\\n    <field name=\\\"x_studio_etd\\\" string=\\\"ETD\\\"/>\\n    <field name=\\\"x_studio_oa\\\" string=\\\"OA\\\"/>\\n    <field name=\\\"x_studio_is_work_order\\\" string=\\\"Work Order\\\"/>\\n    <field name=\\\"incoterm_id\\\" readonly=\\\"(state == 'to approve') or (state == 'purchase')\\\" can_create=\\\"True\\\" can_write=\\\"True\\\"/><field name=\\\"incoterm_location\\\" readonly=\\\"state == 'done'\\\"/><field name=\\\"x_studio_last_confirmation\\\" invisible=\\\"1\\\"/>\\n  \\n                <field name=\\\"is_shipped\\\" invisible=\\\"1\\\"/>\\n                            <field name=\\\"id\\\" invisible=\\\"1\\\"/>\\n                            <field name=\\\"company_id\\\" invisible=\\\"1\\\" readonly=\\\"state in ['cancel', 'done', 'purchase']\\\" on_change=\\\"1\\\" can_create=\\\"True\\\" can_write=\\\"True\\\"/>\\n                            \\n                            <field name=\\\"tax_calculation_rounding_method\\\" invisible=\\\"1\\\"/>\\n                        </group>\\n                        <group>\\n                            <field name=\\\"date_order\\\" invisible=\\\"state in ('purchase', 'done')\\\" readonly=\\\"state in ['cancel', 'done', 'purchase']\\\" string=\\\"Order Date\\\" on_change=\\\"1\\\"/>\\n    <field name=\\\"currency_id\\\" force_save=\\\"1\\\" readonly=\\\"state in ['cancel', 'done', 'purchase']\\\" on_change=\\\"1\\\" can_create=\\\"True\\\" can_write=\\\"True\\\"/><field name=\\\"x_studio_order_status\\\" string=\\\"Order Status\\\" widget=\\\"selection\\\"/>\\n                            <label for=\\\"date_approve\\\" invisible=\\\"state not in ('purchase', 'done')\\\"/>\\n                            <div name=\\\"date_approve\\\" invisible=\\\"state not in ('purchase', 'done')\\\" class=\\\"o_row\\\">\\n                                <field name=\\\"date_approve\\\"/>\\n                                <field name=\\\"mail_reception_confirmed\\\" invisible=\\\"1\\\"/>\\n                                <span class=\\\"text-muted\\\" invisible=\\\"not mail_reception_confirmed\\\">(confirmed by vendor)</span>\\n                            </div>\\n                            <label for=\\\"date_planned\\\"/>\\n                            <div name=\\\"date_planned_div\\\" class=\\\"o_row\\\">\\n                                <field name=\\\"date_planned\\\" readonly=\\\"(state == 'purchase') and (state == 'to approve')\\\" string=\\\"Receipt Date\\\" on_change=\\\"1\\\"/>\\n                                <field name=\\\"mail_reminder_confirmed\\\" invisible=\\\"1\\\"/>\\n                                <span class=\\\"text-muted\\\" invisible=\\\"not mail_reminder_confirmed\\\">(confirmed by vendor)</span>\\n                <div>\\n                    <button name=\\\"541\\\" class=\\\"oe_link\\\" type=\\\"action\\\" context=\\\"{'search_default_partner_id': partner_id}\\\" invisible=\\\"state in ['purchase', 'done'] or not partner_id\\\">\\n                        <span invisible=\\\"on_time_rate &lt; 0\\\"><field name=\\\"on_time_rate\\\" widget=\\\"integer\\\" class=\\\"oe_inline\\\" on_change=\\\"1\\\"/>% On-Time Delivery</span>\\n                        <span invisible=\\\"on_time_rate &gt;= 0\\\">No On-time Delivery Data</span>\\n                    </button>\\n                </div>\\n                            </div>\\n                            <label for=\\\"receipt_reminder_email\\\" class=\\\"d-none\\\" invisible=\\\"effective_date\\\"/>\\n                            <div name=\\\"reminder\\\" class=\\\"o_row\\\" title=\\\"Automatically send a confirmation email to the vendor X days before the expected receipt date, asking him to confirm the exact date.\\\" invisible=\\\"effective_date\\\">\\n                                <field name=\\\"receipt_reminder_email\\\"/>\\n                                <span>Ask confirmation</span>\\n                                <div class=\\\"o_row oe_inline\\\" invisible=\\\"not receipt_reminder_email\\\">\\n                                    <field name=\\\"reminder_date_before_receipt\\\"/>\\n                                    day(s) before\\n                                    <widget name=\\\"toaster_button\\\" button_name=\\\"send_reminder_preview\\\" title=\\\"Preview the reminder email by sending it to yourself.\\\" invisible=\\\"not id\\\"/>\\n                                </div>\\n                            </div>\\n                <field name=\\\"picking_type_id\\\" domain=\\\"[('code','=','incoming'), '|', ('warehouse_id', '=', False), ('warehouse_id.company_id', '=', company_id)]\\\" options=\\\"{'no_create': True}\\\" readonly=\\\"state in ['cancel', 'done', 'purchase']\\\" on_change=\\\"1\\\" can_create=\\\"True\\\" can_write=\\\"False\\\"/>\\n                <field name=\\\"dest_address_id\\\" invisible=\\\"default_location_dest_id_usage != 'customer'\\\" readonly=\\\"state in ['cancel', 'done', 'purchase']\\\" required=\\\"default_location_dest_id_usage == 'customer'\\\" can_create=\\\"True\\\" can_write=\\\"True\\\"/>\\n                <field name=\\\"effective_date\\\" invisible=\\\"not effective_date\\\"/>\\n    <field name=\\\"x_studio_eta_1\\\" string=\\\"ETA\\\"/>\\n    <field name=\\\"payment_term_id\\\" readonly=\\\"state == 'purchase'\\\" options=\\\"{'no_create': True}\\\" force_save=\\\"True\\\" required=\\\"1\\\" can_create=\\\"True\\\" can_write=\\\"True\\\"/><field name=\\\"shipment_mode\\\" string=\\\"Shipment Mode\\\" readonly=\\\"(state == 'purchase') or (state == 'to approve')\\\" options=\\\"{'no_create': True, 'no_open': True}\\\" can_create=\\\"True\\\" can_write=\\\"True\\\"/>\\n                    <field name=\\\"origin\\\" required=\\\"True\\\"/><!-- <field name=\\\"itemtype\\\" required=\\\"True\\\"/> -->\\n                    <field name=\\\"itemtypes\\\" required=\\\"True\\\" can_create=\\\"True\\\" can_write=\\\"True\\\"/>\\n                    <field name=\\\"po_type\\\" readonly=\\\"state in 'cancel','done', 'purchase', 'to approve'\\\" required=\\\"True\\\"/>\\n                    <field name=\\\"exp_consum_date\\\"/>\\n                    <field name=\\\"cshipment\\\" readonly=\\\"True\\\" invisible=\\\"True\\\"/>\\n                    <field name=\\\"invoice_report_date\\\"/>\\n                    <field name=\\\"cause_of_change\\\" readonly=\\\"True\\\"/>\\n                        </group>\\n                    </group>\\n                    <notebook>\\n                        <page string=\\\"Products\\\" name=\\\"products\\\">\\n                            <field name=\\\"tax_country_id\\\" invisible=\\\"1\\\"/>\\n                            <field name=\\\"order_line\\\" widget=\\\"section_and_note_one2many\\\" mode=\\\"tree,kanban\\\" context=\\\"{'default_state': 'draft'}\\\" readonly=\\\"state in ['cancel', 'done', 'to approve']\\\" on_change=\\\"1\\\">\\n                                <tree string=\\\"Purchase Order Lines\\\" editable=\\\"bottom\\\">\\n                                    <control>\\n                                        <create name=\\\"add_product_control\\\" string=\\\"Add a product\\\"/>\\n                                        <create name=\\\"add_section_control\\\" string=\\\"Add a section\\\" context=\\\"{'default_display_type': 'line_section'}\\\"/>\\n                                        <create name=\\\"add_note_control\\\" string=\\\"Add a note\\\" context=\\\"{'default_display_type': 'line_note'}\\\"/>\\n                                        <button name=\\\"action_add_from_catalog\\\" string=\\\"Catalog\\\" type=\\\"object\\\" class=\\\"px-4 btn-link\\\" context=\\\"{'order_id': parent.id}\\\"/>\\n                                    </control>\\n                                    <field name=\\\"tax_calculation_rounding_method\\\" column_invisible=\\\"True\\\"/>\\n                                    <field name=\\\"display_type\\\" column_invisible=\\\"True\\\"/>\\n                                    <field name=\\\"company_id\\\" column_invisible=\\\"True\\\" on_change=\\\"1\\\"/>\\n                                    <field name=\\\"currency_id\\\" column_invisible=\\\"True\\\"/>\\n                                    <field name=\\\"state\\\" column_invisible=\\\"True\\\"/>\\n                                    <field name=\\\"product_type\\\" column_invisible=\\\"True\\\"/>\\n                                    \\n                                    <field name=\\\"product_uom_category_id\\\" column_invisible=\\\"True\\\"/>\\n                                    <field name=\\\"invoice_lines\\\" column_invisible=\\\"True\\\" on_change=\\\"1\\\"/>\\n                                    <field name=\\\"sequence\\\" widget=\\\"handle\\\"/>\\n                                    <field name=\\\"product_id\\\" readonly=\\\"(state == 'purchase') or (state == 'to approve')\\\" required=\\\"display_type == False\\\" width=\\\"35%\\\" context=\\\"{'partner_id':parent.partner_id, 'quantity':product_qty, 'company_id': parent.company_id}\\\" force_save=\\\"1\\\" domain=\\\"[('purchase_ok', '=', True)]\\\" options=\\\"{&quot;no_create&quot;:true}\\\" on_change=\\\"1\\\" can_create=\\\"True\\\" can_write=\\\"True\\\"/>\\n                                    <field name=\\\"name\\\" readonly=\\\"(state == 'purchase') or (state == 'to approve')\\\"/>\\n    <field name=\\\"x_studio_purchase_description\\\" string=\\\"Purchase Description\\\" column_invisible=\\\"True\\\"/>\\n                                    <field name=\\\"date_planned\\\" optional=\\\"hide\\\" required=\\\"not display_type\\\" force_save=\\\"1\\\" on_change=\\\"1\\\"/>\\n                <field name=\\\"move_dest_ids\\\" column_invisible=\\\"True\\\" on_change=\\\"1\\\" can_create=\\\"True\\\" can_write=\\\"True\\\"/>\\n                <field name=\\\"propagate_cancel\\\" optional=\\\"hide\\\"/>\\n                                    <field name=\\\"analytic_distribution\\\" widget=\\\"analytic_distribution\\\" optional=\\\"hide\\\" options=\\\"{'product_field': 'product_id', 'business_domain': 'purchase_order', 'amount_field': 'price_subtotal'}\\\"/>\\n                   <field name=\\\"quality_standard\\\" optional=\\\"hide\\\"/>\\n                                    <field name=\\\"product_qty\\\" readonly=\\\"(state == 'to approve') or (state == 'purchase')\\\" on_change=\\\"1\\\"/>\\n                <field name=\\\"forecasted_issue\\\" column_invisible=\\\"True\\\"/>\\n                <button type=\\\"object\\\" name=\\\"action_product_forecast_report\\\" title=\\\"Forecast Report\\\" icon=\\\"fa-area-chart\\\" invisible=\\\"not id or not forecasted_issue or product_type != 'product'\\\" class=\\\"text-danger\\\"/>\\n                <button type=\\\"object\\\" name=\\\"action_product_forecast_report\\\" title=\\\"Forecast Report\\\" icon=\\\"fa-area-chart\\\" invisible=\\\"not id or forecasted_issue or product_type != 'product'\\\"/>\\n                                    <field name=\\\"qty_received_manual\\\" column_invisible=\\\"True\\\" on_change=\\\"1\\\"/>\\n                                    <field name=\\\"qty_received_method\\\" column_invisible=\\\"True\\\" on_change=\\\"1\\\"/>\\n                                    <field name=\\\"qty_received\\\" string=\\\"Received\\\" column_invisible=\\\"parent.state not in ('purchase', 'done')\\\" readonly=\\\"product_type in ('consu', 'product')\\\" optional=\\\"show\\\" on_change=\\\"1\\\"/>\\n                                    <field name=\\\"qty_invoiced\\\" string=\\\"Billed\\\" column_invisible=\\\"parent.state not in ('purchase', 'done')\\\" optional=\\\"show\\\"/>\\n                                    <field name=\\\"product_uom\\\" string=\\\"UoM\\\" readonly=\\\"state in ('purchase', 'done', 'cancel')\\\" required=\\\"not display_type\\\" options=\\\"{'no_open': True}\\\" force_save=\\\"1\\\" optional=\\\"show\\\" on_change=\\\"1\\\" can_create=\\\"True\\\" can_write=\\\"True\\\"/>\\n                                    <field name=\\\"product_packaging_qty\\\" invisible=\\\"not product_id or not product_packaging_id\\\" optional=\\\"hide\\\" on_change=\\\"1\\\"/>\\n                                    <field name=\\\"product_packaging_id\\\" invisible=\\\"not product_id\\\" context=\\\"{'default_product_id': product_id, 'tree_view_ref':'product.product_packaging_tree_view', 'form_view_ref':'product.product_packaging_form_view'}\\\" optional=\\\"hide\\\" on_change=\\\"1\\\" can_create=\\\"True\\\" can_write=\\\"True\\\"/>\\n                   <field name=\\\"last_purchase_price\\\" style=\\\"background-color: #00A09D; color: white\\\"/>\\n                   <field name=\\\"goods_in_transit\\\"/>\\n                                    <field name=\\\"price_unit\\\" readonly=\\\"(state == 'purchase') or (state == 'to approve')\\\" force_save=\\\"True\\\" on_change=\\\"1\\\"/>\\n                                    <button name=\\\"action_purchase_history\\\" type=\\\"object\\\" icon=\\\"fa-history\\\" title=\\\"Purchase History\\\" invisible=\\\"not id\\\"/>\\n                                    <field name=\\\"taxes_id\\\" widget=\\\"many2many_tags\\\" domain=\\\"[('type_tax_use', '=', 'purchase'), ('company_id', 'parent_of', parent.company_id), ('country_id', '=', parent.tax_country_id), ('active', '=', True)]\\\" context=\\\"{'default_type_tax_use': 'purchase', 'search_view_ref': 'account.account_tax_view_search'}\\\" options=\\\"{'no_create': True}\\\" optional=\\\"show\\\" force_save=\\\"True\\\" readonly=\\\"state == 'purchase'\\\" on_change=\\\"1\\\" can_create=\\\"True\\\" can_write=\\\"True\\\"/>\\n                                    <field name=\\\"discount\\\" string=\\\"Disc.%\\\" readonly=\\\"qty_invoiced != 0\\\" optional=\\\"hide\\\" on_change=\\\"1\\\"/>\\n                                    <field name=\\\"price_subtotal\\\" string=\\\"Tax excl.\\\" on_change=\\\"1\\\"/>\\n                                    <field name=\\\"price_total\\\" string=\\\"Tax incl.\\\" column_invisible=\\\"parent.tax_calculation_rounding_method == 'round_globally'\\\" optional=\\\"hide\\\" on_change=\\\"1\\\"/>\\n                                </tree>\\n                                <form string=\\\"Purchase Order Line\\\">\\n                                        <field name=\\\"tax_calculation_rounding_method\\\" invisible=\\\"1\\\"/>\\n                                        <field name=\\\"state\\\" invisible=\\\"1\\\"/>\\n                                        <field name=\\\"display_type\\\" invisible=\\\"1\\\"/>\\n                                        <field name=\\\"company_id\\\" invisible=\\\"1\\\" on_change=\\\"1\\\"/>\\n                                        <group invisible=\\\"display_type\\\">\\n                                            <group>\\n                                                <field name=\\\"product_uom_category_id\\\" invisible=\\\"1\\\"/>\\n                                                <field name=\\\"product_id\\\" context=\\\"{'partner_id': parent.partner_id}\\\" widget=\\\"many2one_barcode\\\" domain=\\\"[('purchase_ok', '=', True), '|', ('company_id', '=', False), ('company_id', '=', parent.company_id)]\\\" readonly=\\\"state in ('purchase', 'to approve', 'done', 'cancel')\\\" on_change=\\\"1\\\" can_create=\\\"True\\\" can_write=\\\"True\\\"/>\\n                                                <label for=\\\"product_qty\\\"/>\\n                                                <div class=\\\"o_row\\\">\\n                                                    <field name=\\\"product_qty\\\" on_change=\\\"1\\\"/>\\n                                                    <field name=\\\"product_uom\\\" required=\\\"display_type != False\\\" force_save=\\\"True\\\" readonly=\\\"1\\\" on_change=\\\"1\\\"/>\\n                                                </div>\\n                                                <field name=\\\"qty_received_method\\\" invisible=\\\"1\\\" on_change=\\\"1\\\"/>\\n                                                <field name=\\\"qty_received\\\" string=\\\"Received Quantity\\\" invisible=\\\"parent.state not in ['purchase', 'done']\\\" readonly=\\\"qty_received_method != 'manual'\\\" on_change=\\\"1\\\"/>\\n                                                <field name=\\\"qty_invoiced\\\" string=\\\"Billed Quantity\\\" invisible=\\\"parent.state not in ('purchase', 'done')\\\"/>\\n                                                <field name=\\\"product_packaging_qty\\\" invisible=\\\"not product_id or not product_packaging_id\\\" on_change=\\\"1\\\"/>\\n                                                <field name=\\\"product_packaging_id\\\" invisible=\\\"not product_id\\\" context=\\\"{'default_product_id': product_id, 'tree_view_ref':'product.product_packaging_tree_view', 'form_view_ref':'product.product_packaging_form_view'}\\\" on_change=\\\"1\\\" can_create=\\\"True\\\" can_write=\\\"True\\\"/>\\n                                                <field name=\\\"price_unit\\\" readonly=\\\"state == 'purchase'\\\" on_change=\\\"1\\\"/>\\n                                                <field name=\\\"taxes_id\\\" widget=\\\"many2many_tags\\\" domain=\\\"[('type_tax_use', '=', 'purchase'), ('company_id', 'parent_of', parent.company_id), ('country_id', '=', parent.tax_country_id)]\\\" options=\\\"{'no_create': True}\\\" on_change=\\\"1\\\" can_create=\\\"True\\\" can_write=\\\"True\\\"/>\\n                                            </group>\\n                                            <group>\\n                                                <field name=\\\"date_planned\\\" widget=\\\"date\\\" required=\\\"not display_type\\\" on_change=\\\"1\\\"/>\\n                <field name=\\\"propagate_cancel\\\"/>\\n                                                <field name=\\\"analytic_distribution\\\" widget=\\\"analytic_distribution\\\" options=\\\"{'product_field': 'product_id', 'business_domain': 'purchase_order'}\\\"/>\\n                                            </group>\\n                                            <group>\\n                                            <notebook colspan=\\\"4\\\">\\n                                                <page string=\\\"Notes\\\" name=\\\"notes\\\">\\n                                                    <field name=\\\"name\\\"/>\\n                                                </page>\\n                                                <page string=\\\"Invoices and Incoming Shipments\\\" name=\\\"invoices_incoming_shiptments\\\">\\n                                                    <field name=\\\"invoice_lines\\\" on_change=\\\"1\\\"/>\\n                <field name=\\\"move_ids\\\" on_change=\\\"1\\\"/>\\n                                                </page>\\n                                            </notebook>\\n                                            </group>\\n                                        </group>\\n                                        <label for=\\\"name\\\" string=\\\"Section Name (eg. Products, Services)\\\" invisible=\\\"display_type != 'line_section'\\\"/>\\n                                        <label for=\\\"name\\\" string=\\\"Note\\\" invisible=\\\"display_type != 'line_note'\\\"/>\\n                                        <field name=\\\"name\\\" nolabel=\\\"1\\\" invisible=\\\"not display_type\\\"/>\\n                                </form>\\n                                <kanban class=\\\"o_kanban_mobile\\\">\\n                                     <field name=\\\"name\\\"/>\\n                                     <field name=\\\"product_id\\\" on_change=\\\"1\\\"/>\\n                                     <field name=\\\"product_qty\\\" on_change=\\\"1\\\"/>\\n                                     <field name=\\\"product_uom\\\" on_change=\\\"1\\\"/>\\n                                     <field name=\\\"price_subtotal\\\" on_change=\\\"1\\\"/>\\n                                     <field name=\\\"price_tax\\\"/>\\n                                     <field name=\\\"price_total\\\" on_change=\\\"1\\\"/>\\n                                     <field name=\\\"price_unit\\\" on_change=\\\"1\\\"/>\\n                                     <field name=\\\"display_type\\\"/>\\n                                     <field name=\\\"taxes_id\\\" on_change=\\\"1\\\"/>\\n                                     <field name=\\\"tax_calculation_rounding_method\\\"/>\\n                                     <templates>\\n                                         <t t-name=\\\"kanban-box\\\">\\n                                             <div t-attf-class=\\\"oe_kanban_card oe_kanban_global_click {{ record.display_type.raw_value ? 'o_is_' + record.display_type.raw_value : '' }}\\\">\\n                                                 <t t-if=\\\"!record.display_type.raw_value\\\">\\n                                                     <div class=\\\"row\\\">\\n                                                         <div class=\\\"col-8\\\">\\n                                                             <strong>\\n                                                                 <span t-esc=\\\"record.product_id.value\\\"/>\\n                                                             </strong>\\n                                                         </div>\\n                                                         <div class=\\\"col-4\\\">\\n                                                             <strong>\\n                                                                 <span>\\n                                                                     Tax excl.: <t t-esc=\\\"record.price_subtotal.value\\\" class=\\\"float-end text-end\\\"/>\\n                                                                 </span>\\n                                                             </strong>\\n                                                         </div>\\n                                                     </div>\\n                                                     <div class=\\\"row\\\">\\n                                                         <div class=\\\"col-8 text-muted\\\">\\n                                                             <span>\\n                                                                 Quantity:\\n                                                                 <t t-esc=\\\"record.product_qty.value\\\"/>\\n                                                                 <t t-esc=\\\"record.product_uom.value\\\"/>\\n                                                             </span>\\n                                                         </div>\\n                                                         <div class=\\\"col-4\\\" t-if=\\\"record.tax_calculation_rounding_method.raw_value === 'round_per_line'\\\">\\n                                                             <strong>\\n                                                                <span>\\n                                                                    Tax incl.: <t t-esc=\\\"record.price_total.value\\\"/>\\n                                                                </span>\\n                                                             </strong>\\n                                                         </div>\\n                                                     </div>\\n                                                     <div class=\\\"row\\\">\\n                                                         <div class=\\\"col-12 text-muted\\\">\\n                                                             <span>\\n                                                                 Unit Price:\\n                                                                 <t t-esc=\\\"record.price_unit.value\\\"/>\\n                                                             </span>\\n                                                         </div>\\n                                                     </div>\\n                                                 </t>\\n                                                 <div t-elif=\\\"record.display_type.raw_value === 'line_section' || record.display_type.raw_value === 'line_note'\\\" class=\\\"row\\\">\\n                                                     <div class=\\\"col-12\\\">\\n                                                         <span t-esc=\\\"record.name.value\\\"/>\\n                                                     </div>\\n                                                 </div>\\n                                             </div>\\n                                         </t>\\n                                     </templates>\\n                                 </kanban>\\n                            </field>\\n                            <group>\\n                                <group>\\n                                    <field colspan=\\\"2\\\" name=\\\"notes\\\" nolabel=\\\"1\\\" placeholder=\\\"Define your terms and conditions ...\\\"/>\\n                                </group>\\n                                <group class=\\\"oe_subtotal_footer\\\">\\n                                    <field name=\\\"tax_totals\\\" widget=\\\"account-tax-totals-field\\\" nolabel=\\\"1\\\" colspan=\\\"2\\\" readonly=\\\"1\\\"/>\\n                                </group>\\n                            </group>\\n                            <div class=\\\"clearfix\\\"/>\\n                        </page>\\n                        <page string=\\\"Other Information\\\" name=\\\"purchase_delivery_invoice\\\">\\n                            <group>\\n                                <group name=\\\"other_info\\\">\\n                                    <field name=\\\"user_id\\\" domain=\\\"[('share', '=', False)]\\\" widget=\\\"many2one_avatar_user\\\" can_create=\\\"True\\\" can_write=\\\"True\\\"/>\\n                                    <field name=\\\"company_id\\\" options=\\\"{'no_create': True}\\\" readonly=\\\"state in ['cancel', 'done', 'purchase']\\\" on_change=\\\"1\\\" can_create=\\\"True\\\" can_write=\\\"True\\\"/>\\n                                    \\n                <field name=\\\"default_location_dest_id_usage\\\" invisible=\\\"1\\\"/>\\n                \\n                \\n                                </group>\\n                                <group name=\\\"invoice_info\\\">\\n                <field name=\\\"receipt_status\\\" invisible=\\\"state not in ('purchase', 'done')\\\"/>\\n                                    <field name=\\\"invoice_status\\\" invisible=\\\"state in ('draft', 'sent', 'to approve', 'cancel')\\\"/>\\n                                    \\n                                    <field name=\\\"fiscal_position_id\\\" options=\\\"{'no_create': True}\\\" readonly=\\\"invoice_status == 'invoiced' or state == 'done'\\\" on_change=\\\"1\\\" can_create=\\\"True\\\" can_write=\\\"True\\\"/>\\n    <field name=\\\"x_studio_hs_code\\\" string=\\\"HS Code\\\"/>\\n                                </group>\\n                            </group>\\n                        </page>\\n                <page string=\\\"Alternatives\\\" name=\\\"alternative_pos\\\">\\n                    <group>\\n                        <group>\\n                            <p colspan=\\\"2\\\">Create a call for tender by adding alternative requests for quotation to different vendors.\\n                            Make your choice by selecting the best combination of lead time, OTD and/or total amount.\\n                            By comparing product lines you can also decide to order some products from one vendor and others from another vendor.</p>\\n                        </group>\\n                        <group>\\n                            <p colspan=\\\"2\\\">\\n                                <button name=\\\"action_create_alternative\\\" type=\\\"object\\\" class=\\\"btn-link d-block\\\" string=\\\"Create Alternative\\\" icon=\\\"fa-copy\\\"/>\\n                                <button name=\\\"action_compare_alternative_lines\\\" type=\\\"object\\\" class=\\\"btn-link d-block\\\" string=\\\"Compare Product Lines\\\" icon=\\\"fa-bar-chart\\\" invisible=\\\"not alternative_po_ids\\\"/>\\n                            </p>\\n                        </group>\\n                    </group>\\n                    <field name=\\\"alternative_po_ids\\\" readonly=\\\"not id\\\" widget=\\\"many2many_alt_pos\\\" context=\\\"{'quotation_only': True}\\\">\\n                        <tree string=\\\"Alternative Purchase Order\\\" decoration-muted=\\\"state in ['cancel', 'purchase', 'done']\\\" decoration-bf=\\\"id == parent.id\\\">\\n                            <control>\\n                                <create string=\\\"Link to Existing RfQ\\\"/>\\n                            </control>\\n                            <field name=\\\"currency_id\\\" column_invisible=\\\"1\\\" on_change=\\\"1\\\"/>\\n                            <field name=\\\"partner_id\\\" readonly=\\\"state in ['cancel', 'done', 'purchase']\\\" on_change=\\\"1\\\"/>\\n                <field name=\\\"on_time_rate_perc\\\" widget=\\\"percentage\\\" invisible=\\\"on_time_rate_perc &lt; 0\\\"/>\\n                            <field name=\\\"name\\\" string=\\\"Reference\\\"/>\\n                            <field name=\\\"date_planned\\\" on_change=\\\"1\\\"/>\\n                            <field name=\\\"amount_total\\\" on_change=\\\"1\\\"/>\\n                            <field name=\\\"state\\\" on_change=\\\"1\\\"/>\\n                        </tree>\\n                    </field>\\n                </page>\\n                    </notebook>\\n                </sheet>\\n                <div class=\\\"oe_chatter\\\">\\n                    <field name=\\\"message_follower_ids\\\"/>\\n                    <field name=\\\"activity_ids\\\"/>\\n                    <field name=\\\"message_ids\\\"/>\\n                </div>\\n                </form>\", \"id\": 1493, \"model\": \"purchase.order\", \"toolbar\": {\"print\": [{\"id\": 2348, \"name\": \"PURCHASE ACCOUNT REPORT\", \"binding_view_types\": \"list,form\"}, {\"id\": 2349, \"name\": \"PURCHASE VENDOR REPORT\", \"binding_view_types\": \"list,form\"}, {\"id\": 2350, \"name\": \"PURCHASE QOUTATION REPORT\", \"binding_view_types\": \"list,form\"}], \"action\": [{\"id\": 1643, \"name\": \"Accrued Expense Entry\", \"binding_view_types\": \"list,form\"}, {\"id\": 523, \"name\": \"Share\", \"binding_view_types\": \"form\", \"sequence\": 5}, {\"id\": 531, \"name\": \"Create Vendor Bills\", \"binding_view_types\": \"list,form\", \"sequence\": 5}, {\"id\": 532, \"name\": \"Send Reminder\", \"binding_view_types\": \"form\", \"sequence\": 5}, {\"id\": 2375, \"name\": \"Download ZIP Purchase\", \"binding_view_types\": \"list,form\", \"sequence\": 5}]}}, \"pivot\": {\"arch\": \"<pivot string=\\\"Purchase Order\\\" display_quantity=\\\"1\\\" sample=\\\"1\\\">\\n                    <field name=\\\"partner_id\\\" type=\\\"row\\\"/>\\n                    <field name=\\\"amount_total\\\" type=\\\"measure\\\"/>\\n                </pivot>\", \"id\": 1491, \"model\": \"purchase.order\", \"toolbar\": {}}, \"graph\": {\"arch\": \"<graph string=\\\"Purchase Order\\\" sample=\\\"1\\\">\\n                    <field name=\\\"partner_id\\\"/>\\n                    <field name=\\\"amount_total\\\" type=\\\"measure\\\"/>\\n                </graph>\", \"id\": 1492, \"model\": \"purchase.order\", \"toolbar\": {}}, \"calendar\": {\"arch\": \"<calendar string=\\\"Calendar View\\\" date_start=\\\"date_calendar_start\\\" color=\\\"partner_id\\\" hide_time=\\\"true\\\" event_limit=\\\"5\\\" create=\\\"false\\\">\\n                    <field name=\\\"currency_id\\\" invisible=\\\"1\\\"/>\\n                    <field name=\\\"partner_ref\\\"/>\\n                    <field name=\\\"amount_total\\\" widget=\\\"monetary\\\"/>\\n                    <field name=\\\"partner_id\\\" filters=\\\"1\\\"/>\\n                </calendar>\", \"id\": 1490, \"model\": \"purchase.order\", \"toolbar\": {}}, \"activity\": {\"arch\": \"<activity string=\\\"Purchase Order\\\">\\n                    <field name=\\\"currency_id\\\"/>\\n                    <templates>\\n                        <div t-name=\\\"activity-box\\\" class=\\\"d-block\\\">\\n                            <div class=\\\"d-flex justify-content-between\\\">\\n                                <field name=\\\"name\\\" display=\\\"full\\\" class=\\\"o_text_block o_text_bold\\\"/>\\n                                <div class=\\\"m-1\\\"/>\\n                                <field name=\\\"amount_total\\\" widget=\\\"monetary\\\"/>\\n                            </div>\\n                            <div class=\\\"d-flex justify-content-between\\\">\\n                                <field name=\\\"partner_id\\\" muted=\\\"1\\\" display=\\\"full\\\" class=\\\"o_text_block\\\"/>\\n                                <div class=\\\"m-1\\\"/>\\n                                <field name=\\\"state\\\" widget=\\\"badge\\\" decoration-success=\\\"state == 'purchase' or state == 'done'\\\" decoration-warning=\\\"state == 'to approve'\\\" decoration-info=\\\"state == 'draft' or state == 'sent'\\\"/>\\n                            </div>\\n                        </div>\\n                    </templates>\\n                </activity>\", \"id\": 1500, \"model\": \"purchase.order\", \"toolbar\": {}}, \"search\": {\"arch\": \"<search string=\\\"Search Purchase Order\\\">\\n                    <field name=\\\"name\\\" string=\\\"Order\\\" filter_domain=\\\"['|', '|', ('name', 'ilike', self), ('partner_ref', 'ilike', self), ('partner_id', 'child_of', self)]\\\"/>\\n                    <field name=\\\"origin\\\" string=\\\"Appr\\\"/>\\n                    <field name=\\\"partner_id\\\" operator=\\\"child_of\\\"/>\\n                    <field name=\\\"user_id\\\"/>\\n                    <field name=\\\"product_id\\\"/>\\n    <field name=\\\"x_studio_pi_no\\\"/>\\n    <field name=\\\"last_approver\\\"/>\\n                    <field name=\\\"origin\\\"/>\\n                    <filter name=\\\"my_purchases\\\" string=\\\"My Purchases\\\" domain=\\\"[('user_id', '=', uid)]\\\"/>\\n                   <filter string=\\\"RM\\\" name=\\\"rmtype\\\" domain=\\\"[('itemtypes.name', '=', 'Raw Materials')]\\\"/>\\n                   <filter string=\\\"Spare\\\" name=\\\"sparetype\\\" domain=\\\"[('itemtypes.name', '=', 'Spares')]\\\"/>\\n                    <filter string=\\\"Starred\\\" name=\\\"starred\\\" domain=\\\"[('priority', '=', '1')]\\\"/>\\n                    <separator/>\\n                    <filter name=\\\"draft\\\" string=\\\"RFQs\\\" domain=\\\"[('state', 'in', ('draft', 'sent', 'to approve'))]\\\"/>\\n                    <separator/>\\n                    <filter name=\\\"approved\\\" string=\\\"Purchase Orders\\\" domain=\\\"[('state', 'in', ('purchase', 'done'))]\\\"/>\\n                <filter string=\\\"Requisition\\\" name=\\\"requisition\\\" domain=\\\"[('requisition_id', '!=', False)]\\\" help=\\\"Purchase Orders with requisition\\\"/>\\n                    <filter name=\\\"to_approve\\\" string=\\\"To Approve\\\" domain=\\\"[('state', '=', 'to approve')]\\\"/>\\n                    <separator/>\\n                    <filter name=\\\"order_date\\\" string=\\\"Order Date\\\" date=\\\"date_order\\\"/>\\n                   <filter name=\\\"po_order_date\\\" string=\\\"PO Date\\\" domain=\\\"[[&quot;date_approve&quot;,&quot;&gt;=&quot;,&quot;2023-01-1&quot;]]\\\"/>\\n<!--                    domain=\\\"[('date_order', '>=', '2022-04-01 00:00:00'),('date_order','&lt;', '2022-04-30 23:59:59')]\\\" -->\\n<!--                    [\\\"date_order\\\",\\\">=\\\",\\\"2022-03-31 18:00:00\\\"],[\\\"date_order\\\",\\\"<=\\\",\\\"2022-04-30 17:59:59\\\"] ,('date_order','=', '2022-04-30 23:59:59') \\\"search_default_rmtype\\\": true, ('date_order', '>=', '2022-04-01 00:00:00'),('date_order','&lt;', '2022-04-30 23:59:59')-->\\n                    <filter name=\\\"draft_rfqs\\\" string=\\\"Draft RFQs\\\" domain=\\\"[('state', '=', 'draft')]\\\"/>\\n                    <filter name=\\\"waiting_rfqs\\\" string=\\\"Waiting RFQs\\\" domain=\\\"[('state', '=', 'sent'), ('date_order', '&gt;=', datetime.datetime.now())]\\\"/>\\n                    <filter name=\\\"late_rfqs\\\" string=\\\"Late RFQs\\\" domain=\\\"[('state', 'in', ['draft', 'sent', 'to approve']),('date_order', '&lt;', datetime.datetime.now())]\\\"/>\\n                    <separator/>\\n                    <filter invisible=\\\"1\\\" string=\\\"Late Activities\\\" name=\\\"activities_overdue\\\" domain=\\\"[('my_activity_date_deadline', '&lt;', context_today().strftime('%Y-%m-%d'))]\\\" help=\\\"Show all records which has next action date is before today\\\"/>\\n                    <filter invisible=\\\"1\\\" string=\\\"Today Activities\\\" name=\\\"activities_today\\\" domain=\\\"[('my_activity_date_deadline', '=', context_today().strftime('%Y-%m-%d'))]\\\"/>\\n                    <filter invisible=\\\"1\\\" string=\\\"Future Activities\\\" name=\\\"activities_upcoming_all\\\" domain=\\\"[('my_activity_date_deadline', '&gt;', context_today().strftime('%Y-%m-%d'))]\\\"/>\\n                    <separator/>\\n                    <filter string=\\\"Warnings\\\" name=\\\"activities_exception\\\" domain=\\\"[('activity_exception_decoration', '!=', False)]\\\"/>\\n                    <group expand=\\\"0\\\" string=\\\"Group By\\\">\\n                        <filter string=\\\"Vendor\\\" name=\\\"vendor\\\" domain=\\\"[]\\\" context=\\\"{'group_by': 'partner_id'}\\\"/>\\n                        <filter string=\\\"Purchase Representative\\\" name=\\\"representative\\\" domain=\\\"[]\\\" context=\\\"{'group_by': 'user_id'}\\\"/>\\n                        <filter string=\\\"Order Date\\\" name=\\\"order_date\\\" domain=\\\"[]\\\" context=\\\"{'group_by': 'date_order'}\\\"/>\\n    <filter name=\\\"studio_group_by_AfjIS\\\" string=\\\"Status\\\" context=\\\"{'group_by': 'state'}\\\"/>\\n                    </group>\\n                </search>\", \"id\": 1494, \"model\": \"purchase.order\", \"toolbar\": {}, \"filters\":